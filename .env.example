# Google OAuth credentials
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id-here
GOOGLE_CLIENT_SECRET=your-client-secret-here

# App settings
SECRET_KEY=change-me-to-a-random-secret-key
BASE_URL=http://localhost:8000

# Database (Docker uses /data/ mount; local dev uses ./survivor.db by default)
DATABASE_URL=sqlite:////data/survivor.db

# Admin email (this user can update elimination order)
ADMIN_EMAIL=you@example.com

# Email (optional — enables rankings email feature)
# Get a Gmail App Password at https://myaccount.google.com/apppasswords
SMTP_EMAIL=your-gmail@gmail.com
SMTP_PASSWORD=your-app-password
